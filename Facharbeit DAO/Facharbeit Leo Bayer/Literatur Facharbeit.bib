@misc{badari2021,
	address = {Rochester, NY},
	type = {{SSRN} {Scholarly} {Paper}},
	title = {An {Overview} of {Bitcoin} and {Ethereum} {White}-{Papers}, {Forks}, and {Prices}},
	url = {https://papers.ssrn.com/abstract=3841827},
	doi = {10.2139/ssrn.3841827},
	abstract = {We will be reviewing the two most popular cryptocurrencies, Bitcoin and Ethereum. Specifically, we will be reviewing the basic concepts outlined in their respective white papers, as well as some of their most significant forks. Not only will we discuss the technical changes brought by the forks, but we will also analyze the effects these forks have on the coin’s performance in the markets. Our research will involve analyzing the white papers of these coins, and the changes made by significant forks that have been added over the years. In doing so, we hope to develop an understanding of what security protocols are primarily used by each coin, and how they differ. A lot of cryptocurrencies have a reputation of being both underrated and overhyped simultaneously, so we will be reviewing our coins in the context of demand as it relates to security and performance. We will be measuring hype, or public sentiment, using technical factors such as Market Cap, Daily Volume, and Circulating Volume. Finally, we will comment on whether the forks themselves had an impact on the demand of the currency, as measured by its technical factors. We will see if there is any correlation between a useful fork being released and any sudden movements in market sentiment. Our paper will consist of three parts: a summary of the chosen cryptocurrencies white papers, the changes brought on by significant forks, and the past and current market demand behind them.},
	language = {en},
	urldate = {2023-04-10},
	author = {Badari, Ananda and Chaudhury, Archie},
	month = apr,
	year = {2021},
	keywords = {Blockchain, Bitcoin, Ethereum, Market, Software Forks},
	file = {badari2021.pdf:/Users/leo/Library/Mobile Documents/iCloud~md~obsidian/Documents/Library of Babel/zDateien/badari2021.pdf:application/pdf},
}

