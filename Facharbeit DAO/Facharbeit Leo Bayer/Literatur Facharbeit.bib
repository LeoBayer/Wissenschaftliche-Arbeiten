@misc{sims2019,
	address = {Rochester, NY},
	type = {{SSRN} {Scholarly} {Paper}},
	title = {Blockchain and {Decentralised} {Autonomous} {Organisations} ({DAOs}): {The} {Evolution} of {Companies}?},
	shorttitle = {Blockchain and {Decentralised} {Autonomous} {Organisations} ({DAOs})},
	url = {https://papers.ssrn.com/abstract=3524674},
	doi = {10.2139/ssrn.3524674},
	abstract = {Blockchain’s potential uses are wider than simply cryptocurrencies. Blockchain can and is being used to create Decentralised Autonomous Organisations (DAOs). DAOs represent a radical rethink of how organisations, such as companies, can be structured and run, including changes in ownership, governance, decision-making and profit distribution. DAOs not only lower transaction costs dramatically — and transaction costs are the very reason for a firm’s existence — through their use of smart contracts they can prevent laws and other rules being broken. This article shows that business structures have evolved over the centuries and DAOs are simply another evolution. DAOs require a rethink of the law, including the granting of legal personality to DAOs as well as granting limited liability to DAO token holders.},
	language = {en},
	urldate = {2023-04-05},
	author = {Sims, Alexandra},
	month = nov,
	year = {2019},
	keywords = {DAO, governance, blockchain, company, corporation, distributed autonomous organisations, Distributed Ledger Technology, DLT, limited liability, separate legal personality, smart contracts},
	file = {Sims - 2019 - Blockchain and Decentralised Autonomous Organisati.pdf:/Users/leo/Zotero/storage/TATTW5YF/Sims - 2019 - Blockchain and Decentralised Autonomous Organisati.pdf:application/pdf},
}

